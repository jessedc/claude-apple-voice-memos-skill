#!/usr/bin/env python3
# SPDX-License-Identifier: 0BSD
"""Export Apple Voice Memos cloud recordings to CSV."""

import argparse
import csv
import os
import sqlite3
import sys
from datetime import datetime, timezone, timedelta

CORE_DATA_EPOCH = datetime(2001, 1, 1, tzinfo=timezone.utc)
VOICE_MEMOS_PATH = "~/Library/Group Containers/group.com.apple.VoiceMemos.shared/Recordings/"


def get_default_database_path():
    """Auto-detect the CloudRecordings.db path."""
    recordings_dir = os.path.expanduser(VOICE_MEMOS_PATH)
    db_path = os.path.join(recordings_dir, "CloudRecordings.db")
    if not os.path.exists(db_path):
        print(f"Error: Database not found at {db_path}", file=sys.stderr)
        print("Voice Memos iCloud sync may not be enabled on this Mac.", file=sys.stderr)
        sys.exit(1)
    return db_path


def format_duration(seconds):
    if seconds is None:
        return ""
    total = int(seconds)
    h, remainder = divmod(total, 3600)
    m, s = divmod(remainder, 60)
    if h > 0:
        return f"{h}:{m:02d}:{s:02d}"
    return f"{m}:{s:02d}"


def core_data_to_iso8601(timestamp):
    if timestamp is None:
        return ""
    dt = CORE_DATA_EPOCH + timedelta(seconds=timestamp)
    return dt.isoformat()


def iso_to_core_data(iso_date):
    """Convert an ISO date string (YYYY-MM-DD) to Core Data timestamp."""
    dt = datetime.strptime(iso_date, "%Y-%m-%d").replace(tzinfo=timezone.utc)
    return (dt - CORE_DATA_EPOCH).total_seconds()


def parse_args():
    parser = argparse.ArgumentParser(description="Query Apple Voice Memos metadata")
    parser.add_argument("--limit", type=int, default=10, help="Max rows to return (default: 10)")
    parser.add_argument("--offset", type=int, default=0, help="Skip first N results")
    parser.add_argument("--search", type=str, help="Filter by title (case-insensitive substring match)")
    parser.add_argument("--after", type=str, help="Only recordings after this date (YYYY-MM-DD)")
    parser.add_argument("--before", type=str, help="Only recordings before this date (YYYY-MM-DD)")
    parser.add_argument("--print-path", action="store_true", help="Print the Voice Memos path and exit")
    return parser.parse_args()


def main():
    args = parse_args()

    if args.print_path:
        print(VOICE_MEMOS_PATH)
        return

    db_path = get_default_database_path()
    conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)

    where_clauses = []
    params = []

    if args.search:
        where_clauses.append("ZENCRYPTEDTITLE LIKE ?")
        params.append(f"%{args.search}%")

    if args.after:
        where_clauses.append("ZDATE >= ?")
        params.append(iso_to_core_data(args.after))

    if args.before:
        where_clauses.append("ZDATE <= ?")
        params.append(iso_to_core_data(args.before))

    where_sql = (" WHERE " + " AND ".join(where_clauses)) if where_clauses else ""

    query = f"SELECT ZENCRYPTEDTITLE, ZDATE, ZDURATION, ZPATH FROM ZCLOUDRECORDING{where_sql} ORDER BY ZDATE DESC LIMIT ? OFFSET ?"
    params.extend([args.limit, args.offset])

    rows = conn.execute(query, params).fetchall()
    conn.close()

    writer = csv.writer(sys.stdout)
    writer.writerow(["title", "date", "duration", "path"])
    for title, date, duration, path in rows:
        writer.writerow([title, core_data_to_iso8601(date), format_duration(duration), path])


if __name__ == "__main__":
    main()
