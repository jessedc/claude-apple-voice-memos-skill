#!/usr/bin/env python3
# SPDX-License-Identifier: 0BSD
"""Export Apple Voice Memos cloud recordings to CSV."""

import csv
import os
import sqlite3
import sys
from datetime import datetime, timezone, timedelta

CORE_DATA_EPOCH = datetime(2001, 1, 1, tzinfo=timezone.utc)
VOICE_MEMOS_PATH = "~/Library/Group Containers/group.com.apple.VoiceMemos.shared/Recordings/"


def get_default_database_path():
    """Auto-detect the CloudRecordings.db path."""
    recordings_dir = os.path.expanduser(VOICE_MEMOS_PATH)
    db_path = os.path.join(recordings_dir, "CloudRecordings.db")
    if not os.path.exists(db_path):
        print(f"Error: Database not found at {db_path}", file=sys.stderr)
        print("Voice Memos iCloud sync may not be enabled on this Mac.", file=sys.stderr)
        sys.exit(1)
    return db_path


def format_duration(seconds):
    if seconds is None:
        return ""
    total = int(seconds)
    h, remainder = divmod(total, 3600)
    m, s = divmod(remainder, 60)
    if h > 0:
        return f"{h}:{m:02d}:{s:02d}"
    return f"{m}:{s:02d}"


def core_data_to_iso8601(timestamp):
    if timestamp is None:
        return ""
    dt = CORE_DATA_EPOCH + timedelta(seconds=timestamp)
    return dt.isoformat()


def main():
    db_path = get_default_database_path()
    conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
    rows = conn.execute(
        """
        SELECT ZENCRYPTEDTITLE, ZDATE, ZDURATION, ZPATH
        FROM ZCLOUDRECORDING
        ORDER BY ZDATE DESC
        LIMIT 30
        """
    ).fetchall()
    conn.close()

    writer = csv.writer(sys.stdout)
    writer.writerow(["title", "date", "duration", "path"])
    for title, date, duration, path in rows:
        writer.writerow([title, core_data_to_iso8601(date), format_duration(duration), path])


if __name__ == "__main__":
    main()
